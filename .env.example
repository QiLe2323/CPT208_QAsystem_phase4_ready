# Copy this file to .env and fill in your own keys.
# Do not commit real API keys to Git.

# Cloud database
# Supabase / Render / Railway PostgreSQL connection string.
DATABASE_URL=
DATABASE_SSL=true

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
# Use the host URL shown in your Pinecone index dashboard.
# Example: https://your-index-name-xxxx.svc.aped-4627-b74a.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=cpt208
PINECONE_TOP_K=5
PINECONE_MIN_SCORE=0.58

# Coze / 扣子 service endpoint
# Use a long random value and configure the same value in the Coze plugin header.
COZE_SERVICE_KEY=
